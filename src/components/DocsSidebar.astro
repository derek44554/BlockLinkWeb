---
import { getCollection, type CollectionEntry } from 'astro:content';
import type { Locale } from '../i18n/site';
import { pathWithLocale } from '../i18n/site';

interface Props {
  currentSlug?: string;
  locale?: Locale;
  docsCollection?: 'docsEn' | 'docsZh';
}

const {
  currentSlug,
  locale = 'en',
  docsCollection = locale === 'zh' ? 'docsZh' : 'docsEn',
} = Astro.props;

const allDocs = await getCollection(docsCollection);

const groups: Record<string, CollectionEntry<'docsEn'>[] | CollectionEntry<'docsZh'>[]> = {};
for (const doc of allDocs) {
  const [project] = doc.id.split('/');
  if (!groups[project]) groups[project] = [];
  groups[project].push(doc);
}
for (const key of Object.keys(groups)) {
  groups[key].sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
}

const isZh = locale === 'zh';

const projects = [
  { id: 'docs-home', icon: '📚', label: isZh ? '文档中心' : 'Docs Center', href: pathWithLocale(locale, '/docs') },
  { id: 'guide', icon: '🚀', label: isZh ? '快速开始' : 'Getting Started' },
  { id: 'concepts', icon: '💡', label: isZh ? '核心概念' : 'Core Concepts' },
  { id: 'blockbase', icon: '🖥️', label: 'BlockBase' },
  { id: 'blocklink', icon: '🐍', label: 'BlockLink Python' },
];

const currentProject = currentSlug ? currentSlug.split('/')[0] : null;

const blockbaseAppsDocs = (groups['blockbase'] ?? []).filter((d) => d.id.startsWith('blockbase/apps/'));
const blockbaseMainDocs = (groups['blockbase'] ?? []).filter((d) => !d.id.startsWith('blockbase/apps/'));
const blockbaseSubGroups: Record<string, (CollectionEntry<'docsEn'> | CollectionEntry<'docsZh'>)[]> = {};
for (const doc of blockbaseAppsDocs) {
  const parts = doc.id.split('/');
  const sub = parts[2] ?? 'other';
  if (!blockbaseSubGroups[sub]) blockbaseSubGroups[sub] = [];
  blockbaseSubGroups[sub].push(doc);
}
for (const key of Object.keys(blockbaseSubGroups)) {
  blockbaseSubGroups[key].sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
}

const projectDefaultLabel = isZh ? '选择项目' : 'Select Project';
const appsLabel = 'Apps';
const backHomeLabel = isZh ? '返回主站' : 'Back to Main Site';
const languageLabel = isZh ? 'EN' : '中文';
const languageHref = pathWithLocale(isZh ? 'en' : 'zh', currentSlug ? `/docs/${currentSlug}` : '/docs');
---

<aside class="sidebar">
  <a href={pathWithLocale(locale, '/')} class="sidebar-logo">
    <span class="logo-hex">⬡</span>
    <span class="logo-name">BlockLink</span>
  </a>

  <div class="project-switcher">
    <button class="switcher-btn" id="projectSwitcherBtn">
      <span class="switcher-icon">{projects.find(p => p.id === currentProject)?.icon ?? '📚'}</span>
      <span class="switcher-label">{projects.find(p => p.id === currentProject)?.label ?? projectDefaultLabel}</span>
      <svg class="switcher-arrow" width="12" height="12" viewBox="0 0 16 16" fill="none">
        <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <div class="project-dropdown" id="projectDropdown">
      {projects.map(project => {
        let href: string;
        if (project.id === 'docs-home') {
          href = pathWithLocale(locale, '/docs');
        } else {
          const projectDocs = groups[project.id] ?? [];
          const firstDoc = projectDocs[0];
          href = firstDoc ? pathWithLocale(locale, `/docs/${firstDoc.id}`) : pathWithLocale(locale, '/docs');
        }
        const isActive = project.id === 'docs-home' ? !currentSlug : currentProject === project.id;
        return (
          <a
            href={href}
            class:list={['dropdown-item', { active: isActive }]}
          >
            <span class="item-icon">{project.icon}</span>
            <span class="item-label">{project.label}</span>
          </a>
        );
      })}
    </div>
  </div>

  <nav class="sidebar-nav">
    {currentProject === 'guide' && (
      <div class="doc-list">
        {(groups['guide'] ?? []).map(doc => {
          const isActive = doc.id === currentSlug;
          return (
            <a href={pathWithLocale(locale, `/docs/${doc.id}`)} class:list={['doc-link', { active: isActive }]}> 
              {doc.data.title}
            </a>
          );
        })}
      </div>
    )}

    {currentProject === 'concepts' && (
      <div class="doc-list">
        {(groups['concepts'] ?? []).map(doc => {
          const isActive = doc.id === currentSlug;
          return (
            <a href={pathWithLocale(locale, `/docs/${doc.id}`)} class:list={['doc-link', { active: isActive }]}> 
              {doc.data.title}
            </a>
          );
        })}
      </div>
    )}

    {currentProject === 'blockbase' && (
      <div class="doc-list">
        {blockbaseMainDocs.map(doc => {
          const isActive = doc.id === currentSlug;
          return (
            <a href={pathWithLocale(locale, `/docs/${doc.id}`)} class:list={['doc-link', { active: isActive }]}> 
              {doc.data.title}
            </a>
          );
        })}
        {Object.keys(blockbaseSubGroups).length > 0 && (
          <div class="apps-section">
            <div class="apps-header">
              <span class="apps-icon">📦</span>
              <span class="apps-title">{appsLabel}</span>
            </div>
            <div class="apps-list">
              {Object.values(blockbaseSubGroups).flat().map(doc => {
                const isActive = doc.id === currentSlug;
                return (
                  <a href={pathWithLocale(locale, `/docs/${doc.id}`)} class:list={['app-link', { active: isActive }]}> 
                    <span class="app-dot"></span>
                    {doc.data.title}
                  </a>
                );
              })}
            </div>
          </div>
        )}
      </div>
    )}

    {currentProject === 'blocklink' && (
      <div class="doc-list">
        {(groups['blocklink'] ?? []).map(doc => {
          const isActive = doc.id === currentSlug;
          return (
            <a href={pathWithLocale(locale, `/docs/${doc.id}`)} class:list={['doc-link', { active: isActive }]}> 
              {doc.data.title}
            </a>
          );
        })}
      </div>
    )}
  </nav>

  <div class="sidebar-footer">
    <a href={languageHref} class="lang-switch">{languageLabel}</a>
    <a href={pathWithLocale(locale, '/')} class="back-home">
      <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
        <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {backHomeLabel}
    </a>
  </div>
</aside>

<style>
  .sidebar {
    width: 256px;
    flex-shrink: 0;
    border-right: 1px solid var(--color-border);
    background: var(--color-bg);
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .sidebar-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1rem 0.75rem;
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text);
    transition: opacity 0.2s;
  }
  .sidebar-logo:hover {
    opacity: 0.8;
  }
  .logo-hex {
    color: var(--color-primary);
    font-size: 1.25rem;
    line-height: 1;
  }
  .logo-name {
    letter-spacing: -0.01em;
  }

  .project-switcher {
    padding: 0 1rem 1rem;
    border-bottom: 1px solid var(--color-border);
    position: relative;
  }
  .switcher-btn {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.8rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .switcher-btn:hover {
    border-color: var(--color-primary);
    background: rgba(108, 99, 255, 0.05);
  }
  .switcher-icon {
    font-size: 1.1rem;
  }
  .switcher-label {
    flex: 1;
    text-align: left;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .switcher-arrow {
    color: var(--color-muted);
    transition: transform 0.2s;
  }
  .switcher-btn.open .switcher-arrow {
    transform: rotate(180deg);
  }

  .project-dropdown {
    position: absolute;
    top: calc(100% - 4px);
    left: 1rem;
    right: 1rem;
    background: #13131f;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.35rem;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.45);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px);
    transition: opacity 0.15s, transform 0.15s;
    z-index: 20;
  }
  .project-dropdown.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.5rem 0.6rem;
    border-radius: 8px;
    color: var(--color-muted);
    font-size: 0.85rem;
    transition: background 0.15s, color 0.15s;
  }
  .dropdown-item:hover {
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text);
  }
  .dropdown-item.active {
    background: rgba(108, 99, 255, 0.14);
    color: #d5d2ff;
  }

  .sidebar-nav {
    flex: 1;
    padding: 1rem 0.8rem;
  }
  .doc-list {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .doc-link,
  .app-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.65rem;
    border-radius: 8px;
    color: var(--color-muted);
    font-size: 0.86rem;
    transition: background 0.15s, color 0.15s;
  }
  .doc-link:hover,
  .app-link:hover {
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text);
  }
  .doc-link.active,
  .app-link.active {
    background: rgba(108, 99, 255, 0.14);
    color: #d5d2ff;
    font-weight: 600;
  }

  .apps-section {
    margin-top: 0.6rem;
    padding-top: 0.7rem;
    border-top: 1px dashed var(--color-border);
  }
  .apps-header {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0 0.55rem 0.35rem;
    color: var(--color-muted);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
  }
  .apps-list {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .app-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--color-primary-light);
    opacity: 0.7;
    flex-shrink: 0;
  }

  .sidebar-footer {
    border-top: 1px solid var(--color-border);
    padding: 0.8rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .lang-switch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    height: 28px;
    padding: 0 0.65rem;
    border-radius: 7px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    font-size: 0.78rem;
    transition: color 0.15s, background 0.15s;
  }
  .lang-switch:hover {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.04);
  }
  .back-home {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-muted);
    font-size: 0.82rem;
    transition: color 0.15s;
  }
  .back-home:hover {
    color: var(--color-text);
  }
</style>

<script>
  const switcherBtn = document.getElementById('projectSwitcherBtn');
  const dropdown = document.getElementById('projectDropdown');

  switcherBtn?.addEventListener('click', () => {
    switcherBtn.classList.toggle('open');
    dropdown?.classList.toggle('open');
  });

  document.addEventListener('click', (event) => {
    if (!switcherBtn || !dropdown) return;
    const target = event.target;
    if (!(target instanceof Node)) return;
    if (!switcherBtn.contains(target) && !dropdown.contains(target)) {
      switcherBtn.classList.remove('open');
      dropdown.classList.remove('open');
    }
  });
</script>
