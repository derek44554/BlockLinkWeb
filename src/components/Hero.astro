---
---

<section class="hero" id="hero">
  <div class="hero-bg">
    <div class="grid-overlay"></div>
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
  </div>
  <div class="hero-content">
    <div class="badge">🚀 全新发布 v0.1.0</div>
    <h1 class="hero-title">
      连接一切，<br />
      <span class="gradient-text">构建无限可能</span>
    </h1>
    <p class="hero-desc">
      BlockLink 是一套面向开发者和团队的工具集，帮助你快速集成、自动化工作流，
      让每一个模块都能无缝协作。
    </p>
    <div class="deploy-wrap">
      <div class="deploy-box">
        <span class="deploy-label">一键部署</span>
        <div class="deploy-command">
          <span class="prompt">$</span>
          <code id="deploy-cmd">bash &lt;(curl -fsSL https://raw.githubusercontent.com/derek44554/block_shell/main/start.sh)</code>
        </div>
        <button class="copy-btn" id="copy-btn">复制</button>
      </div>
      <p class="deploy-hint">支持 Ubuntu 20.04+ · Debian 11+ · CentOS 8+</p>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-num">2</span>
        <span class="stat-label">GitHub Star</span>
      </div>
      <div class="divider"></div>
      <div class="stat">
        <span class="stat-num">5</span>
        <span class="stat-label">生态 App</span>
      </div>
      <div class="divider"></div>
      <div class="stat">
        <span class="stat-num">1</span>
        <span class="stat-label">开发者</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 8rem 2rem 4rem;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(108, 99, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(108, 99, 255, 0.05) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.3;
  }
  .glow-1 {
    width: 600px; height: 600px;
    background: var(--color-primary);
    top: -200px; left: -100px;
  }
  .glow-2 {
    width: 400px; height: 400px;
    background: var(--color-accent);
    bottom: -100px; right: 0;
  }
  .hero-content {
    position: relative;
    max-width: 760px;
    text-align: center;
  }
  .badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: rgba(108, 99, 255, 0.15);
    border: 1px solid rgba(108, 99, 255, 0.3);
    border-radius: 100px;
    font-size: 0.85rem;
    color: var(--color-primary-light);
    margin-bottom: 1.5rem;
  }
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }
  .gradient-text {
    background: linear-gradient(135deg, var(--color-primary-light), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-desc {
    font-size: 1.15rem;
    color: var(--color-muted);
    max-width: 560px;
    margin: 0 auto 2.5rem;
    line-height: 1.8;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }
  .btn-cta {
    padding: 0.75rem 2rem;
    background: var(--color-primary);
    color: #fff;
    border-radius: 10px;
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 0 30px rgba(108, 99, 255, 0.4);
  }
  .btn-cta:hover {
    background: var(--color-primary-light);
    transform: translateY(-2px);
    box-shadow: 0 0 40px rgba(108, 99, 255, 0.6);
  }
  .btn-outline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    font-size: 1rem;
    color: var(--color-text);
    transition: border-color 0.2s, background 0.2s;
  }
  .btn-outline:hover {
    border-color: var(--color-primary);
    background: rgba(108, 99, 255, 0.08);
  }
  .deploy-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 3.5rem;
    width: 100%;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }
  .deploy-box {
    display: flex;
    align-items: center;
    gap: 0;
    background: #0d0d16;
    border: 1px solid rgba(108, 99, 255, 0.4);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 0 24px rgba(108,99,255,0.12);
    width: 100%;
    min-width: 0;
  }
  .deploy-label {
    padding: 0 1rem;
    height: 48px;
    display: flex;
    align-items: center;
    font-size: 0.78rem;
    font-weight: 700;
    color: #fff;
    background: rgba(108, 99, 255, 0.5);
    white-space: nowrap;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }
  .deploy-command {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 1.25rem;
    height: 48px;
    flex: 1;
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(108, 99, 255, 0.4) transparent;
  }
  .deploy-command::-webkit-scrollbar {
    height: 3px;
  }
  .deploy-command::-webkit-scrollbar-track {
    background: transparent;
  }
  .deploy-command::-webkit-scrollbar-thumb {
    background: rgba(108, 99, 255, 0.4);
    border-radius: 2px;
  }
  .prompt {
    color: rgba(108, 99, 255, 0.8);
    font-family: monospace;
    font-size: 1rem;
    user-select: none;
    flex-shrink: 0;
  }
  .deploy-command code {
    font-family: 'Fira Code', 'Cascadia Code', 'Courier New', monospace;
    font-size: 0.9rem;
    color: #e8e8f0;
    white-space: nowrap;
  }
  .copy-btn {
    height: 48px;
    padding: 0 1.25rem;
    background: rgba(108, 99, 255, 0.15);
    border: none;
    border-left: 1px solid rgba(108, 99, 255, 0.25);
    color: #8b85ff;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .copy-btn:hover { background: rgba(108,99,255,0.3); color: #fff; }
  .deploy-hint {
    font-size: 0.78rem;
    color: var(--color-muted);
    opacity: 0.6;
  }
  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
  }
  .stat { text-align: center; }
  .stat-num {
    display: block;
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .stat-label {
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .divider {
    width: 1px;
    height: 40px;
    background: var(--color-border);
  }
</style>

<script>
  const cmd = document.getElementById('deploy-cmd')!.innerText;
  const btn = document.getElementById('copy-btn')!;

  btn.addEventListener('click', () => {
    navigator.clipboard.writeText(cmd).then(() => {
      btn.textContent = '✓ 已复制';
      setTimeout(() => btn.textContent = '复制', 2000);
    });
  });
</script>
