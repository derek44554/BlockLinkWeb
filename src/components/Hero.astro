---
import type { Locale } from '../i18n/site';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const isZh = locale === 'zh';

const copy = {
  badge: isZh ? '🚀 全新发布 v0.1.0' : '🚀 New Release v0.1.0',
  titleLine1: isZh ? '连接一切，' : 'Connect Everything,',
  titleLine2: isZh ? '构建无限可能' : 'Build Without Limits',
  desc: isZh
    ? 'BlockLink 是一套面向开发者和团队的工具集，帮助你快速集成、自动化工作流，让每一个模块都能无缝协作。'
    : 'BlockLink is a tool suite for developers and teams to integrate faster, automate workflows, and make every module work together seamlessly.',
  copyBtn: isZh ? '复制' : 'Copy',
  copiedBtn: isZh ? '✓ 已复制' : '✓ Copied',
  hint: isZh ? '支持 Ubuntu 20.04+ · Debian 11+ · CentOS 8+' : 'Supports Ubuntu 20.04+ · Debian 11+ · CentOS 8+',
  apps: isZh ? '生态 App' : 'Ecosystem Apps',
  devs: isZh ? '开发者' : 'Developers',
  copyCompact: isZh ? '复制' : 'Copy',
};
---

<section class="hero" id="hero">
  <div class="hero-bg">
    <div class="grid-overlay"></div>
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
  </div>
  <div class="hero-content">
    <div class="badge">{copy.badge}</div>
    <h1 class="hero-title">
      {copy.titleLine1}<br />
      <span class="gradient-text">{copy.titleLine2}</span>
    </h1>
    <p class="hero-desc">
      {copy.desc}
    </p>
    <div class="deploy-wrap">
      <div class="deploy-box">
        <div class="deploy-command">
          <span class="prompt">$</span>
          <div class="deploy-scroll" aria-label={isZh ? '命令滚动区域' : 'Command scroll area'}>
            <code id="deploy-cmd">bash &lt;(curl -fsSL https://raw.githubusercontent.com/derek44554/block_shell/main/start.sh)</code>
          </div>
        </div>
        <button
          class="copy-btn"
          id="copy-btn"
          data-copy-label={copy.copyBtn}
          data-copy-compact={copy.copyCompact}
          data-copied-label={copy.copiedBtn}
          aria-label={copy.copyBtn}
        >
          {copy.copyBtn}
        </button>
      </div>
      <p class="deploy-hint">{copy.hint}</p>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-num">2</span>
        <span class="stat-label">GitHub Star</span>
      </div>
      <div class="divider"></div>
      <div class="stat">
        <span class="stat-num">5</span>
        <span class="stat-label">{copy.apps}</span>
      </div>
      <div class="divider"></div>
      <div class="stat">
        <span class="stat-num">1</span>
        <span class="stat-label">{copy.devs}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 8rem 2rem 4rem;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(108, 99, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(108, 99, 255, 0.05) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.3;
  }
  .glow-1 {
    width: 600px; height: 600px;
    background: var(--color-primary);
    top: -200px; left: -100px;
  }
  .glow-2 {
    width: 400px; height: 400px;
    background: var(--color-accent);
    bottom: -100px; right: 0;
  }
  .hero-content {
    position: relative;
    max-width: 760px;
    width: 100%;
    text-align: center;
  }
  .badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: rgba(108, 99, 255, 0.15);
    border: 1px solid rgba(108, 99, 255, 0.3);
    border-radius: 100px;
    font-size: 0.85rem;
    color: var(--color-primary-light);
    margin-bottom: 1.5rem;
  }
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }
  .gradient-text {
    background: linear-gradient(135deg, var(--color-primary-light), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-desc {
    font-size: 1.15rem;
    color: var(--color-muted);
    max-width: 560px;
    margin: 0 auto 2.5rem;
    line-height: 1.8;
  }
  .deploy-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 3.5rem;
    width: 100%;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }
  .deploy-box {
    display: flex;
    align-items: center;
    gap: 0;
    background: #0d0d16;
    border: 1px solid rgba(108, 99, 255, 0.4);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 0 24px rgba(108,99,255,0.12);
    width: 100%;
    min-width: 0;
  }
  .deploy-command {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.5rem;
    padding: 0 1.25rem;
    height: 48px;
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-align: left;
  }
  .deploy-scroll {
    flex: 1;
    min-width: 0;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: thin;
    scrollbar-color: rgba(108, 99, 255, 0.4) transparent;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-x;
    overscroll-behavior-x: contain;
    text-align: left;
  }
  .deploy-scroll::-webkit-scrollbar {
    height: 3px;
  }
  .deploy-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .deploy-scroll::-webkit-scrollbar-thumb {
    background: rgba(108, 99, 255, 0.4);
    border-radius: 2px;
  }
  .prompt {
    color: rgba(108, 99, 255, 0.8);
    font-family: monospace;
    font-size: 1rem;
    user-select: none;
    flex-shrink: 0;
  }
  .deploy-scroll code {
    font-family: 'Fira Code', 'Cascadia Code', 'Courier New', monospace;
    font-size: 0.9rem;
    color: #e8e8f0;
    white-space: nowrap;
    display: inline-block;
    min-width: max-content;
    text-align: left;
  }
  .copy-btn {
    height: 48px;
    padding: 0 1.25rem;
    background: rgba(108, 99, 255, 0.15);
    border: none;
    border-left: 1px solid rgba(108, 99, 255, 0.25);
    color: #8b85ff;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 64px;
  }
  .copy-btn:hover { background: rgba(108,99,255,0.3); color: #fff; }
  .deploy-hint {
    font-size: 0.78rem;
    color: var(--color-muted);
    opacity: 0.6;
  }
  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
  }
  .stat { text-align: center; }
  .stat-num {
    display: block;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .stat-label {
    display: block;
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-top: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .divider {
    width: 1px;
    height: 40px;
    background: var(--color-border);
  }

  @media (max-width: 1024px) {
    .deploy-box {
      border-radius: 10px;
    }
    .deploy-command {
      height: 46px;
      padding: 0 0.85rem;
    }
    .deploy-scroll code {
      font-size: 0.82rem;
    }
    .copy-btn {
      min-width: 58px;
      height: 46px;
      padding: 0 0.8rem;
      font-size: 0.76rem;
    }
  }

  @media (max-width: 768px) {
    .hero { padding-top: 7rem; }
    .hero-stats { gap: 1rem; }
    .deploy-wrap {
      max-width: 100%;
    }
    .deploy-box {
      display: flex;
      align-items: stretch;
      border-radius: 10px;
    }
    .deploy-command {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      min-width: 0;
      height: 46px;
      padding: 0 0.85rem;
      overflow: hidden;
    }
    .deploy-scroll code {
      font-size: 0.78rem;
      white-space: nowrap;
    }
    .copy-btn {
      width: auto;
      min-width: 72px;
      height: 46px;
      padding: 0 0.9rem;
      font-size: 0.75rem;
      border-top: none;
      border-left: 1px solid rgba(108, 99, 255, 0.25);
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-inline: 1rem;
    }
    .deploy-command {
      height: 44px;
      padding: 0 0.75rem;
    }
    .deploy-scroll code {
      font-size: 0.74rem;
    }
    .copy-btn {
      min-width: 56px;
      height: 44px;
      padding: 0 0.75rem;
      font-size: 0.72rem;
    }
    .deploy-hint {
      text-align: center;
      padding-inline: 0.5rem;
    }
  }
</style>

<script>
  const copyBtn = document.getElementById('copy-btn');
  const deployCmd = document.getElementById('deploy-cmd');
  const deployScroll = document.querySelector('.deploy-scroll');
  const compactMedia = window.matchMedia('(max-width: 480px)');
  const desktopNarrowMedia = window.matchMedia('(max-width: 1024px)');

  const updateCopyLabel = () => {
    if (!copyBtn) return;
    const isCopied = copyBtn.dataset.state === 'copied';
    if (isCopied) return;
    const compactLabel = copyBtn.dataset.copyCompact ?? copyBtn.dataset.copyLabel ?? 'Copy';
    const fullLabel = copyBtn.dataset.copyLabel ?? 'Copy';
    copyBtn.textContent = compactMedia.matches ? compactLabel : fullLabel;
  };

  updateCopyLabel();
  compactMedia.addEventListener('change', updateCopyLabel);
  desktopNarrowMedia.addEventListener('change', () => {
    if (!(deployScroll instanceof HTMLElement)) return;
    deployScroll.scrollLeft = 0;
  });
  if (deployScroll instanceof HTMLElement) {
    deployScroll.scrollLeft = 0;
  }

  copyBtn?.addEventListener('click', async () => {
    try {
      const cmd = deployCmd?.textContent ?? '';
      await navigator.clipboard.writeText(cmd);
      const copiedLabel = copyBtn.dataset.copiedLabel ?? '✓ Copied';
      copyBtn.dataset.state = 'copied';
      copyBtn.textContent = copiedLabel;
      setTimeout(() => {
        if (!copyBtn) return;
        delete copyBtn.dataset.state;
        updateCopyLabel();
      }, 1800);
    } catch {
      // Ignore clipboard errors on unsupported environments.
    }
  });
</script>
