---
import type { Locale } from '../i18n/site';
import { pathWithLocale } from '../i18n/site';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
---

<footer class="footer">
  <div class="container">
    <a href={pathWithLocale(locale, '/')} class="logo">
      <span class="logo-icon">⬡</span>
      <span>BlockLink</span>
    </a>
    <p class="copy">© 2026 BlockLink. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 1.75rem 2rem;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    font-size: 1rem;
  }
  .logo-icon { color: var(--color-primary); }
  .copy {
    font-size: 0.82rem;
    color: var(--color-muted);
  }
</style>
